FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TERM=xterm-256color
ENV LANG=C.UTF-8

RUN apt-get update && apt-get install -y \
  git \
  zsh \
  curl \
  wget \
  unzip \
  ca-certificates \
  ripgrep \
  fd-find \
  fzf \
  tmux \
  neovim \
  rsync \
  build-essential \
  python3 \
  python3-pip \
  bat \
  && rm -rf /var/lib/apt/lists/*

# Install eza (modern ls replacement)
RUN curl -sSL https://github.com/eza-community/eza/releases/download/v0.20.23/eza_x86_64-unknown-linux-gnu.tar.gz | tar xz -C /usr/local/bin ./eza

# Install Odin compiler from source
RUN apt-get update && apt-get install -y clang llvm make && rm -rf /var/lib/apt/lists/*
RUN git clone --depth 1 https://github.com/odin-lang/Odin.git /opt/odin && \
    cd /opt/odin && make release-native
ENV PATH="/opt/odin:$PATH"
ENV ODIN_ROOT="/opt/odin"

RUN useradd -ms /bin/zsh dev

USER dev
WORKDIR /home/dev

# Install Oh My Zsh
RUN sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
# Download .shrc from .files dotfiles
RUN curl -fsSL https://raw.githubusercontent.com/yesitsfebreeze/.files/main/.zshrc -o ~/.zshrc

# Disable docker plugin and mount function when running inside container
RUN grep -q '/.dockerenv' /proc/1/cgroup 2>/dev/null && \
    sed -i 's/plugins=(git docker 1password macos)/plugins=(git 1password macos)/' ~/.zshrc && \
    sed -i "s/alias dk=.*/alias dk='echo Docker not available inside container'/" ~/.zshrc && \
    echo 'mount() { echo "Cannot mount from inside container"; }' >> ~/.zshrc || true

# Install opencode CLI
RUN curl -fsSL https://opencode.ai/install | bash
ENV PATH="/home/dev/.local/bin:$PATH"

WORKDIR /workspace
VOLUME /workspace

CMD ["zsh"]
