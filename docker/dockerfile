FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    zsh \
    git \
    curl \
    wget \
    unzip \
    ca-certificates \
    ripgrep \
    fd-find \
    fzf \
    tmux \
    neovim \
    build-essential \
    python3 \
    python3-pip \
 && rm -rf /var/lib/apt/lists/*

RUN useradd -ms /bin/zsh dev

USER dev
WORKDIR /workspace
VOLUME /workspace

CMD ["zsh"]
