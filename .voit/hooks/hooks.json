{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/role-scope.sh\"",
            "timeout": 15,
            "statusMessage": "VOIT: deriving role + scope…"
          },
          {
            "type": "command",
            "command": "command -v jd >/dev/null 2>&1 || curl -fsSL https://raw.githubusercontent.com/yesitsfebreeze/justdown/main/scripts/install.sh | sh || sh \"${CLAUDE_PLUGIN_ROOT}/skills/justdown/resources/install.sh\"",
            "timeout": 120,
            "statusMessage": "justdown: ensuring jd is installed…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/write-scope.py\"",
            "timeout": 15,
            "statusMessage": "VOIT: write-scope guard…"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/bus.py\" peek 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "VOIT: checking the bus…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__.*justdown.*__(get|search)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/jd-usage.py\" || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/bus.py\" gc >/dev/null 2>&1 || true",
            "timeout": 10,
            "statusMessage": "VOIT: flushing the bus…"
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/jd-cache.py\" populate >/dev/null 2>&1 || true",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
