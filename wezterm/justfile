# justfile — WezTerm dotfiles dependency installer
# Usage:  just install  |  just check

set windows-shell := ["powershell", "-NoProfile", "-Command"]

# ── Dependencies ─────────────────────────────────────────────────
#  Name       Binary    winget                  brew          apt/dnf      pacman
#  ─────────  ────────  ──────────────────────  ────────────  ───────────  ────────
#  ripgrep    rg        BurntSushi.ripgrep      ripgrep       ripgrep      ripgrep
#  fzf        fzf       junegunn.fzf            fzf           fzf          fzf
#  bat        bat       sharkdp.bat             bat           bat          bat
#  python     python    Python.Python.3.12      python@3      python3      python
#  wezterm    wezterm   wez.wezterm             --cask        (website)    (website)

check_bins  := "wezterm rg bat fzf python"

winget_ids  := "BurntSushi.ripgrep junegunn.fzf sharkdp.bat Python.Python.3.12 wez.wezterm"
winget_opts := "--accept-source-agreements --accept-package-agreements -e"

brew_pkgs   := "ripgrep fzf bat python@3"
brew_casks  := "wezterm"

apt_pkgs    := "ripgrep fzf bat python3"
dnf_pkgs    := "ripgrep fzf bat python3"
pacman_pkgs := "ripgrep fzf bat python"

# ── Install ──────────────────────────────────────────────────────

[windows]
install:
    @echo "Installing dependencies (winget)..."
    @foreach ($id in "{{winget_ids}}".Split()) { winget install --id $id {{winget_opts}} }
    @echo "`nDone. Restart your terminal so new commands are on PATH."

[macos]
install:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Installing dependencies (brew)..."
    command -v brew &>/dev/null || /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    brew install {{brew_pkgs}}
    brew install --cask {{brew_casks}}
    echo -e "\nDone."

[linux]
install:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Installing dependencies (Linux)..."
    if command -v apt-get &>/dev/null; then
        sudo apt-get update && sudo apt-get install -y {{apt_pkgs}}
    elif command -v dnf &>/dev/null; then
        sudo dnf install -y {{dnf_pkgs}}
    elif command -v pacman &>/dev/null; then
        sudo pacman -S --noconfirm {{pacman_pkgs}}
    else
        echo "No supported package manager found. Install manually: {{check_bins}}"
        exit 1
    fi
    # Debian/Ubuntu ships bat as batcat
    if ! command -v bat &>/dev/null && command -v batcat &>/dev/null; then
        sudo ln -sf "$(command -v batcat)" /usr/local/bin/bat
    fi
    if ! command -v wezterm &>/dev/null; then
        echo "Install WezTerm from: https://wezfurlong.org/wezterm/install/linux.html"
    fi
    echo -e "\nDone."

# ── Check ────────────────────────────────────────────────────────

[unix]
check:
    #!/usr/bin/env bash
    ok=true
    for cmd in {{check_bins}}; do
        if command -v "$cmd" &>/dev/null; then
            printf "  ✓ %-12s %s\n" "$cmd" "$(command -v "$cmd")"
        else
            printf "  ✗ %-12s NOT FOUND\n" "$cmd"; ok=false
        fi
    done
    $ok && echo -e "\nAll dependencies installed." || { echo -e "\nSome missing — run: just install"; exit 1; }

[windows]
check:
    @$ok = $true
    @foreach ($c in "{{check_bins}}".Split()) { $p = Get-Command $c -ErrorAction SilentlyContinue; if ($p) { Write-Host "  ✓ $($c.PadRight(12)) $($p.Source)" } else { Write-Host "  ✗ $($c.PadRight(12)) NOT FOUND"; $ok = $false } }
    @if ($ok) { Write-Host "`nAll dependencies installed." } else { Write-Host "`nSome missing — run: just install"; exit 1 }
