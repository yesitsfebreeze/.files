#!/usr/bin/env bash
# chezmoi run_onchange — let `sudo` resolve the user-local tool dirs
# (~/.local/bin, ~/.cargo/bin) so `sudo just`, `sudo nu`, `sudo chezmoi`, … find
# the same binaries the interactive shell does, instead of failing under sudo's
# restricted secure_path. Scoped to this user (Defaults:user), validated with
# `visudo -c` before install so a typo can never lock sudo out. Re-runs whenever
# the rendered path below changes.
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

# sudoers.d only exists on sudo-based systems; no-op elsewhere.
[ -d /etc/sudoers.d ] || { log "no /etc/sudoers.d; skipping sudo PATH setup"; exit 0; }

home="{{ .chezmoi.homeDir }}"
user="{{ .chezmoi.username }}"
dropin="/etc/sudoers.d/10-${user}-path"
secure_path="$home/.local/bin:$home/.cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/snap/bin"
content="Defaults:${user} secure_path=\"$secure_path\""

# Need root to write /etc/sudoers.d. Allow an interactive sudo prompt (matching
# how the package installer already uses sudo), but never hang a non-interactive
# apply (CI, `! just`): if we can't get root without prompting and there's no tty,
# print the one-liner and bail — non-fatal, the rest of the apply continues.
if [ "$(id -u)" = 0 ]; then
    SUDO=""
elif sudo -n true >/dev/null 2>&1 || [ -t 0 ]; then
    SUDO="sudo"
else
    warn "sudo PATH drop-in needs root; run once manually:"
    warn "  echo '$content' | sudo install -m 0440 /dev/stdin $dropin"
    exit 0
fi

# Idempotent across machines with the same home: skip the write (and any sudo
# prompt) when the drop-in already holds exactly this line.
current="$($SUDO cat "$dropin" 2>/dev/null || true)"
if [ "$current" = "$content" ]; then
    log "sudo PATH drop-in already current ($dropin)"
    exit 0
fi

# Validate the candidate file in isolation BEFORE touching the real one — a
# sudoers file visudo rejects would break sudo entirely, so never install it.
tmp="$(mktemp)"
printf '%s\n' "$content" > "$tmp"
if $SUDO visudo -cf "$tmp" >/dev/null 2>&1; then
    $SUDO install -m 0440 -o root -g root "$tmp" "$dropin" \
        && log "sudo now sees $home/.local/bin + ~/.cargo/bin for $user ($dropin)" \
        || warn "could not install $dropin"
else
    warn "generated sudoers line failed validation; not installing"
fi
rm -f "$tmp"
