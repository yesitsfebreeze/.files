#!/usr/bin/env bash
# chezmoi run_onchange — installs/updates the CLI tool set on Unix.
# Re-runs automatically whenever the rendered package list below changes.
#
# packages.yaml sha256: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

# Pick up a Homebrew that run_once_before_install-homebrew may have just installed
# in this same `chezmoi apply` (its shellenv is not yet on our PATH).
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -x /usr/local/bin/brew ] && eval "$(/usr/local/bin/brew shellenv)"

# Package lists rendered from .chezmoidata/packages.yaml (empty fields omitted).
names="{{ range .packages }}{{ .name }} {{ end }}"
brew_pkgs="{{ range .packages }}{{ with .brew }}{{ . }} {{ end }}{{ end }}"
apt_pkgs="{{ range .packages }}{{ with .apt }}{{ . }} {{ end }}{{ end }}"
pacman_pkgs="{{ range .packages }}{{ with .pacman }}{{ . }} {{ end }}{{ end }}"
dnf_pkgs="{{ range .packages }}{{ with .dnf }}{{ . }} {{ end }}{{ end }}"

# --- Detect package manager ---
if command -v brew >/dev/null 2>&1; then
    MGR=brew
elif command -v apt-get >/dev/null 2>&1; then
    MGR=apt
elif command -v pacman >/dev/null 2>&1; then
    MGR=pacman
elif command -v dnf >/dev/null 2>&1; then
    MGR=dnf
else
    warn "No supported package manager found (brew/apt/pacman/dnf)."
    warn "Install Homebrew (https://brew.sh) for a one-command experience, then re-run: chezmoi apply"
    MGR=none
fi
log "Package manager: $MGR"

install_one() {
    pkg="$1"
    case "$MGR" in
        brew)   brew install "$pkg" >/dev/null 2>&1 || brew install --cask "$pkg" >/dev/null 2>&1 ;;
        apt)    sudo apt-get install -y "$pkg" >/dev/null 2>&1 ;;
        pacman) sudo pacman -S --needed --noconfirm "$pkg" >/dev/null 2>&1 ;;
        dnf)    sudo dnf install -y "$pkg" >/dev/null 2>&1 ;;
        *)      return 1 ;;
    esac
}

if [ "$MGR" != none ]; then
    case "$MGR" in
        brew)   pkgs="$brew_pkgs" ;;
        apt)    pkgs="$apt_pkgs"; sudo apt-get update -y >/dev/null 2>&1 || true ;;
        pacman) pkgs="$pacman_pkgs" ;;
        dnf)    pkgs="$dnf_pkgs" ;;
    esac
    for p in $pkgs; do
        log "install $p"
        install_one "$p" || warn "  could not install $p via $MGR (will try fallback)"
    done
fi

# --- Debian/Ubuntu rename: batcat -> bat, fdfind -> fd ---
mkdir -p "$HOME/.local/bin"
command -v batcat >/dev/null 2>&1 && [ ! -e "$HOME/.local/bin/bat" ] && ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
command -v fdfind >/dev/null 2>&1 && [ ! -e "$HOME/.local/bin/fd" ]  && ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"

# --- nushell: prebuilt-binary fallback (no apt package, avoid slow source build) ---
# Nushell isn't in Debian/Ubuntu apt and `cargo install nu` is a heavy source
# build, so on Linux we fetch the prebuilt binary from the GitHub release when
# it's missing. Runs BEFORE the cargo fallback below so cargo skips the build.
# macOS is covered by brew. Idempotent. Mirrors the zellij fallback.
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
if [ "$(uname -s)" = "Linux" ] && ! command -v nu >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)  nu_arch=x86_64 ;;
        aarch64|arm64) nu_arch=aarch64 ;;
        *)             nu_arch="" ;;
    esac
    if [ -n "$nu_arch" ]; then
        # Resolve the latest tag — nushell assets are version-stamped (unlike zellij).
        nu_tag="$(curl -fsSL https://api.github.com/repos/nushell/nushell/releases/latest 2>/dev/null \
            | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')"
        if [ -n "$nu_tag" ]; then
            log "install nushell $nu_tag ($nu_arch musl binary, GitHub release fallback)"
            mkdir -p "$HOME/.local/bin"
            nt="$(mktemp -d)"
            nu_asset="nu-$nu_tag-$nu_arch-unknown-linux-musl.tar.gz"
            if curl -fsSL -o "$nt/$nu_asset" \
                "https://github.com/nushell/nushell/releases/download/$nu_tag/$nu_asset" \
                && tar -xzf "$nt/$nu_asset" -C "$nt" 2>/dev/null; then
                nu_bin="$(find "$nt" -type f -name nu 2>/dev/null | head -n1)"
                if [ -n "$nu_bin" ] && cp "$nu_bin" "$HOME/.local/bin/nu"; then
                    chmod +x "$HOME/.local/bin/nu"
                    log "  installed nushell"
                else
                    warn "  downloaded but could not place the nushell binary"
                fi
            else
                warn "  could not download nushell from the GitHub release"
            fi
            rm -rf "$nt"
        else
            warn "nushell: could not resolve latest release tag; will rely on cargo fallback"
        fi
    else
        warn "nushell: no prebuilt binary for $(uname -m); install manually"
    fi
fi

# --- television: prebuilt-binary fallback (no apt/dnf package, avoid source build) ---
# Television (binary `tv`) isn't in Debian/Ubuntu apt or Fedora dnf, and
# `cargo install television` is a heavy source build, so on Linux we fetch the
# prebuilt binary from the GitHub release when it's missing. Runs BEFORE the
# cargo fallback below so cargo skips the build (and cargo stays the last resort
# if this download fails). macOS is covered by brew. Assets are version-stamped,
# so resolve the tag first (mirrors the nushell fallback). musl ships only for
# x86_64; aarch64 uses the gnu build. Idempotent.
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
if [ "$(uname -s)" = "Linux" ] && ! command -v tv >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)  tv_target=x86_64-unknown-linux-musl ;;
        aarch64|arm64) tv_target=aarch64-unknown-linux-gnu ;;
        *)             tv_target="" ;;
    esac
    if [ -n "$tv_target" ]; then
        tv_tag="$(curl -fsSL https://api.github.com/repos/alexpasmantier/television/releases/latest 2>/dev/null \
            | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')"
        if [ -n "$tv_tag" ]; then
            log "install television $tv_tag ($tv_target binary, GitHub release fallback)"
            mkdir -p "$HOME/.local/bin"
            tt="$(mktemp -d)"
            tv_asset="tv-$tv_tag-$tv_target.tar.gz"
            if curl -fsSL -o "$tt/$tv_asset" \
                "https://github.com/alexpasmantier/television/releases/download/$tv_tag/$tv_asset" \
                && tar -xzf "$tt/$tv_asset" -C "$tt" 2>/dev/null; then
                tv_bin="$(find "$tt" -type f -name tv 2>/dev/null | head -n1)"
                if [ -n "$tv_bin" ] && cp "$tv_bin" "$HOME/.local/bin/tv"; then
                    chmod +x "$HOME/.local/bin/tv"
                    log "  installed television"
                else
                    warn "  downloaded but could not place the television binary"
                fi
            else
                warn "  could not download television from the GitHub release"
            fi
            rm -rf "$tt"
        else
            warn "television: could not resolve latest release tag; will rely on cargo fallback"
        fi
    else
        warn "television: no prebuilt binary for $(uname -m); install manually"
    fi
fi

# --- cargo fallback for tools the native manager could not provide ---
bin_for() {
    case "$1" in
        ripgrep)    echo rg ;;
        neovim)     echo nvim ;;
        nushell)    echo nu ;;
        television) echo tv ;;
        *)          echo "$1" ;;
    esac
}
crate_for() {
    case "$1" in
        rg) echo ripgrep ;;
        fd) echo fd-find ;;
        bat) echo bat ;;
        eza) echo eza ;;
        zoxide) echo zoxide ;;
        starship) echo starship ;;
        delta) echo git-delta ;;
        nu) echo nu ;;
        tv) echo television ;;
        *) echo "" ;;
    esac
}
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
if command -v cargo >/dev/null 2>&1; then
    for n in $names; do
        [ "$n" = "nerd-font" ] && continue
        b="$(bin_for "$n")"
        command -v "$b" >/dev/null 2>&1 && continue
        crate="$(crate_for "$b")"
        [ -z "$crate" ] && continue
        log "cargo install $crate (fallback for $b)"
        cargo install "$crate" >/dev/null 2>&1 || warn "  cargo install $crate failed"
    done
fi

# --- zellij: prebuilt-binary fallback (no apt package, avoid source build) ---
# Zellij isn't in Debian/Ubuntu apt and building the crate from source is heavy,
# so on Linux we fetch the static musl binary from the GitHub release when it's
# missing. macOS is covered by brew. Idempotent.
if [ "$(uname -s)" = "Linux" ] && ! command -v zellij >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)        zj_arch=x86_64 ;;
        aarch64|arm64)       zj_arch=aarch64 ;;
        *)                   zj_arch="" ;;
    esac
    if [ -n "$zj_arch" ]; then
        log "install zellij ($zj_arch musl binary, GitHub release fallback)"
        mkdir -p "$HOME/.local/bin"
        zt="$(mktemp -d)"
        zj_asset="zellij-$zj_arch-unknown-linux-musl.tar.gz"
        if curl -fsSL -o "$zt/$zj_asset" \
            "https://github.com/zellij-org/zellij/releases/latest/download/$zj_asset" \
            && tar -xzf "$zt/$zj_asset" -C "$zt" 2>/dev/null \
            && cp "$zt/zellij" "$HOME/.local/bin/zellij" 2>/dev/null; then
            chmod +x "$HOME/.local/bin/zellij"
            log "  installed zellij"
        else
            warn "  could not install zellij from the GitHub release"
        fi
        rm -rf "$zt"
    else
        warn "zellij: no prebuilt binary for $(uname -m); install manually"
    fi
fi

# --- Nerd Font: guarantee the patched font is present (release fallback) ---
# Font identity comes from packages.yaml (nerdfont_asset); fetch the nerd-fonts
# release zip when the font is not already installed, so the terminal/prompt
# glyphs always resolve regardless of package-manager coverage. Idempotent.
nerdfont_asset="{{ range .packages }}{{ if hasKey . "nerdfont_asset" }}{{ .nerdfont_asset }}{{ end }}{{ end }}"
if [ -n "$nerdfont_asset" ]; then
    case "$(uname -s)" in
        Darwin) font_dir="$HOME/Library/Fonts" ;;
        *)      font_dir="$HOME/.local/share/fonts" ;;
    esac
    have_font=1
    ls "$font_dir/$nerdfont_asset"*.ttf >/dev/null 2>&1 || have_font=0
    if [ "$have_font" = 0 ] && command -v fc-list >/dev/null 2>&1; then
        fc-list 2>/dev/null | grep -qi "$nerdfont_asset" && have_font=1
    fi
    if [ "$have_font" = 0 ]; then
        log "install Nerd Font $nerdfont_asset (nerd-fonts release fallback)"
        mkdir -p "$font_dir"
        ft="$(mktemp -d)"
        if curl -fsSL -o "$ft/$nerdfont_asset.zip" \
            "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/$nerdfont_asset.zip"; then
            if command -v unzip >/dev/null 2>&1; then
                unzip -oq "$ft/$nerdfont_asset.zip" '*.ttf' -d "$ft/ttf" 2>/dev/null
            elif command -v python3 >/dev/null 2>&1; then
                python3 -m zipfile -e "$ft/$nerdfont_asset.zip" "$ft/ttf" >/dev/null 2>&1
            else
                mkdir -p "$ft/ttf" && tar -xf "$ft/$nerdfont_asset.zip" -C "$ft/ttf" 2>/dev/null
            fi
            if cp "$ft/ttf"/*.ttf "$font_dir"/ 2>/dev/null; then
                command -v fc-cache >/dev/null 2>&1 && fc-cache -f "$font_dir" >/dev/null 2>&1
                log "  installed $nerdfont_asset"
            else
                warn "  downloaded but could not place $nerdfont_asset .ttf files"
            fi
        else
            warn "  could not download $nerdfont_asset from the nerd-fonts release"
        fi
        rm -rf "$ft"
    fi
fi

# --- bat: rebuild theme cache ---
# The active theme ({{ .theme.names.bat }}) is built into bat, so no theme file
# is fetched; just rebuild the cache so a fresh install picks it up.
if command -v bat >/dev/null 2>&1; then
    bat cache --build >/dev/null 2>&1 || true
fi

# --- Report anything still missing ---
missing=""
for n in $names; do
    [ "$n" = "nerd-font" ] && continue
    b="$(bin_for "$n")"
    command -v "$b" >/dev/null 2>&1 || missing="$missing $b"
done
if [ -n "$missing" ]; then
    warn "Still missing:$missing"
    warn "Install these manually, or use Homebrew (covers all of them) and re-run: chezmoi apply"
else
    log "All tools present."
fi
