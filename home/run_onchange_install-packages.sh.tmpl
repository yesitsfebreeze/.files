#!/usr/bin/env bash
# chezmoi run_onchange — installs/updates the CLI tool set on Unix.
# Re-runs automatically whenever the rendered package list below changes.
#
# packages.yaml sha256: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

# Pick up a Homebrew that run_once_before_install-homebrew may have just installed
# in this same `chezmoi apply` (its shellenv is not yet on our PATH).
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -x /usr/local/bin/brew ] && eval "$(/usr/local/bin/brew shellenv)"

# User-local bin dirs on PATH for every fallback below (and for tools a previous
# step installed there within this same apply). Set once.
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# Resolve the latest release tag (e.g. "0.99.1") for a GitHub repo "owner/name".
gh_latest_tag() {
    curl -fsSL "https://api.github.com/repos/$1/releases/latest" 2>/dev/null \
        | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/'
}

# Download the tarball at $2 and install the binary named $1 into ~/.local/bin.
# Warns + returns non-zero on any download/extract/place failure, so the cargo
# fallback can still try. Callers guard on `command -v`, so this stays idempotent.
fetch_tarball_binary() {
    _bin="$1"; _url="$2"; _rc=1
    mkdir -p "$HOME/.local/bin"
    _td="$(mktemp -d)"
    if curl -fsSL -o "$_td/asset.tar.gz" "$_url" \
        && tar -xzf "$_td/asset.tar.gz" -C "$_td" 2>/dev/null; then
        _found="$(find "$_td" -type f -name "$_bin" 2>/dev/null | head -n1)"
        if [ -n "$_found" ] && cp "$_found" "$HOME/.local/bin/$_bin"; then
            chmod +x "$HOME/.local/bin/$_bin"; _rc=0
        fi
    fi
    rm -rf "$_td"
    return "$_rc"
}

# Package lists rendered from .chezmoidata/packages.yaml (empty fields omitted).
names="{{ range .packages }}{{ .name }} {{ end }}"
brew_pkgs="{{ range .packages }}{{ with .brew }}{{ . }} {{ end }}{{ end }}"
apt_pkgs="{{ range .packages }}{{ with .apt }}{{ . }} {{ end }}{{ end }}"
pacman_pkgs="{{ range .packages }}{{ with .pacman }}{{ . }} {{ end }}{{ end }}"
dnf_pkgs="{{ range .packages }}{{ with .dnf }}{{ . }} {{ end }}{{ end }}"

# --- Detect package manager ---
if command -v brew >/dev/null 2>&1; then
    MGR=brew
elif command -v apt-get >/dev/null 2>&1; then
    MGR=apt
elif command -v pacman >/dev/null 2>&1; then
    MGR=pacman
elif command -v dnf >/dev/null 2>&1; then
    MGR=dnf
else
    warn "No supported package manager found (brew/apt/pacman/dnf)."
    warn "Install Homebrew (https://brew.sh) for a one-command experience, then re-run: chezmoi apply"
    MGR=none
fi
log "Package manager: $MGR"

install_one() {
    pkg="$1"
    case "$MGR" in
        brew)   brew install "$pkg" >/dev/null 2>&1 || brew install --cask "$pkg" >/dev/null 2>&1 ;;
        apt)    sudo apt-get install -y "$pkg" >/dev/null 2>&1 ;;
        pacman) sudo pacman -S --needed --noconfirm "$pkg" >/dev/null 2>&1 ;;
        dnf)    sudo dnf install -y "$pkg" >/dev/null 2>&1 ;;
        *)      return 1 ;;
    esac
}

if [ "$MGR" != none ]; then
    case "$MGR" in
        brew)   pkgs="$brew_pkgs" ;;
        apt)    pkgs="$apt_pkgs"; sudo apt-get update -y >/dev/null 2>&1 || true ;;
        pacman) pkgs="$pacman_pkgs" ;;
        dnf)    pkgs="$dnf_pkgs" ;;
    esac
    for p in $pkgs; do
        log "install $p"
        install_one "$p" || warn "  could not install $p via $MGR (will try fallback)"
    done
fi

# --- Debian/Ubuntu rename: batcat -> bat, fdfind -> fd ---
mkdir -p "$HOME/.local/bin"
command -v batcat >/dev/null 2>&1 && [ ! -e "$HOME/.local/bin/bat" ] && ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
command -v fdfind >/dev/null 2>&1 && [ ! -e "$HOME/.local/bin/fd" ]  && ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"

# --- prebuilt-binary fallbacks for tools missing from Linux package repos ---
# nushell, television (tv), and zellij aren't in Debian/Ubuntu apt (nor Fedora dnf
# for tv), and `cargo install`-ing them is a heavy source build. So on Linux we
# fetch each prebuilt binary from its GitHub release when missing, BEFORE the
# cargo fallback below (so cargo skips the build and stays the last resort).
# macOS is covered by brew. All guarded by `command -v`, so idempotent.

# nushell — musl binary; assets are version-stamped, so resolve the tag first.
if [ "$(uname -s)" = "Linux" ] && ! command -v nu >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)  nu_arch=x86_64 ;;
        aarch64|arm64) nu_arch=aarch64 ;;
        *)             nu_arch="" ;;
    esac
    nu_tag="$(gh_latest_tag nushell/nushell)"
    if [ -z "$nu_arch" ]; then
        warn "nushell: no prebuilt binary for $(uname -m); install manually"
    elif [ -z "$nu_tag" ]; then
        warn "nushell: could not resolve latest release tag; will rely on cargo fallback"
    else
        log "install nushell $nu_tag ($nu_arch musl binary, GitHub release fallback)"
        fetch_tarball_binary nu \
            "https://github.com/nushell/nushell/releases/download/$nu_tag/nu-$nu_tag-$nu_arch-unknown-linux-musl.tar.gz" \
            && log "  installed nushell" \
            || warn "  could not install nushell from the GitHub release"
    fi
fi

# television (tv) — musl on x86_64, gnu on aarch64; assets are version-stamped.
if [ "$(uname -s)" = "Linux" ] && ! command -v tv >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)  tv_target=x86_64-unknown-linux-musl ;;
        aarch64|arm64) tv_target=aarch64-unknown-linux-gnu ;;
        *)             tv_target="" ;;
    esac
    tv_tag="$(gh_latest_tag alexpasmantier/television)"
    if [ -z "$tv_target" ]; then
        warn "television: no prebuilt binary for $(uname -m); install manually"
    elif [ -z "$tv_tag" ]; then
        warn "television: could not resolve latest release tag; will rely on cargo fallback"
    else
        log "install television $tv_tag ($tv_target binary, GitHub release fallback)"
        fetch_tarball_binary tv \
            "https://github.com/alexpasmantier/television/releases/download/$tv_tag/tv-$tv_tag-$tv_target.tar.gz" \
            && log "  installed television" \
            || warn "  could not install television from the GitHub release"
    fi
fi

# gh (GitHub CLI) — version-stamped tarball. The release tag is "vX.Y.Z" but the
# asset filename drops the leading "v" (gh_X.Y.Z_linux_<arch>.tar.gz), and gh
# names arches amd64/arm64. Extracts to gh_X.Y.Z_linux_<arch>/bin/gh, which
# fetch_tarball_binary finds by name. There is no gh crate, so no cargo fallback.
if [ "$(uname -s)" = "Linux" ] && ! command -v gh >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)  gh_arch=amd64 ;;
        aarch64|arm64) gh_arch=arm64 ;;
        *)             gh_arch="" ;;
    esac
    gh_tag="$(gh_latest_tag cli/cli)"
    gh_ver="${gh_tag#v}"
    if [ -z "$gh_arch" ]; then
        warn "gh: no prebuilt binary for $(uname -m); install manually"
    elif [ -z "$gh_tag" ]; then
        warn "gh: could not resolve latest release tag; install manually"
    else
        log "install gh $gh_tag ($gh_arch binary, GitHub release fallback)"
        fetch_tarball_binary gh \
            "https://github.com/cli/cli/releases/download/$gh_tag/gh_${gh_ver}_linux_${gh_arch}.tar.gz" \
            && log "  installed gh" \
            || warn "  could not install gh from the GitHub release"
    fi
fi

# tinty — musl on x86_64, gnu on aarch64; release assets are tag-agnostic
# (latest/download). Drives the live `theme` switcher; pulled here because no
# Linux package manager ships it. macOS is covered by the auto-tapping brew name.
if [ "$(uname -s)" = "Linux" ] && ! command -v tinty >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)  tinty_target=x86_64-unknown-linux-musl ;;
        aarch64|arm64) tinty_target=aarch64-unknown-linux-gnu ;;
        *)             tinty_target="" ;;
    esac
    if [ -z "$tinty_target" ]; then
        warn "tinty: no prebuilt binary for $(uname -m); will rely on cargo fallback"
    else
        log "install tinty ($tinty_target binary, GitHub release fallback)"
        fetch_tarball_binary tinty \
            "https://github.com/tinted-theming/tinty/releases/latest/download/tinty-$tinty_target.tar.gz" \
            && log "  installed tinty" \
            || warn "  could not install tinty from the GitHub release"
    fi
fi

# --- cargo fallback for tools the native manager could not provide ---
bin_for() {
    case "$1" in
        ripgrep)    echo rg ;;
        neovim)     echo nvim ;;
        nushell)    echo nu ;;
        television) echo tv ;;
        *)          echo "$1" ;;
    esac
}
crate_for() {
    case "$1" in
        rg) echo ripgrep ;;
        fd) echo fd-find ;;
        bat) echo bat ;;
        eza) echo eza ;;
        zoxide) echo zoxide ;;
        starship) echo starship ;;
        delta) echo git-delta ;;
        nu) echo nu ;;
        tv) echo television ;;
        tinty) echo tinty ;;
        *) echo "" ;;
    esac
}
if command -v cargo >/dev/null 2>&1; then
    for n in $names; do
        [ "$n" = "nerd-font" ] && continue
        b="$(bin_for "$n")"
        command -v "$b" >/dev/null 2>&1 && continue
        crate="$(crate_for "$b")"
        [ -z "$crate" ] && continue
        log "cargo install $crate (fallback for $b)"
        cargo install "$crate" >/dev/null 2>&1 || warn "  cargo install $crate failed"
    done
fi

# zellij — static musl binary; release URL is tag-agnostic (latest/download).
if [ "$(uname -s)" = "Linux" ] && ! command -v zellij >/dev/null 2>&1; then
    case "$(uname -m)" in
        x86_64|amd64)  zj_arch=x86_64 ;;
        aarch64|arm64) zj_arch=aarch64 ;;
        *)             zj_arch="" ;;
    esac
    if [ -z "$zj_arch" ]; then
        warn "zellij: no prebuilt binary for $(uname -m); install manually"
    else
        log "install zellij ($zj_arch musl binary, GitHub release fallback)"
        fetch_tarball_binary zellij \
            "https://github.com/zellij-org/zellij/releases/latest/download/zellij-$zj_arch-unknown-linux-musl.tar.gz" \
            && log "  installed zellij" \
            || warn "  could not install zellij from the GitHub release"
    fi
fi

# --- Nerd Font: guarantee the patched font is present (release fallback) ---
# Font identity comes from packages.yaml (nerdfont_asset); fetch the nerd-fonts
# release zip when the font is not already installed, so the terminal/prompt
# glyphs always resolve regardless of package-manager coverage. Idempotent.
nerdfont_asset="{{ range .packages }}{{ if hasKey . "nerdfont_asset" }}{{ .nerdfont_asset }}{{ end }}{{ end }}"
if [ -n "$nerdfont_asset" ]; then
    case "$(uname -s)" in
        Darwin) font_dir="$HOME/Library/Fonts" ;;
        *)      font_dir="$HOME/.local/share/fonts" ;;
    esac
    have_font=1
    ls "$font_dir/$nerdfont_asset"*.ttf >/dev/null 2>&1 || have_font=0
    if [ "$have_font" = 0 ] && command -v fc-list >/dev/null 2>&1; then
        fc-list 2>/dev/null | grep -qi "$nerdfont_asset" && have_font=1
    fi
    if [ "$have_font" = 0 ]; then
        log "install Nerd Font $nerdfont_asset (nerd-fonts release fallback)"
        mkdir -p "$font_dir"
        ft="$(mktemp -d)"
        if curl -fsSL -o "$ft/$nerdfont_asset.zip" \
            "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/$nerdfont_asset.zip"; then
            if command -v unzip >/dev/null 2>&1; then
                unzip -oq "$ft/$nerdfont_asset.zip" '*.ttf' -d "$ft/ttf" 2>/dev/null
            elif command -v python3 >/dev/null 2>&1; then
                python3 -m zipfile -e "$ft/$nerdfont_asset.zip" "$ft/ttf" >/dev/null 2>&1
            else
                mkdir -p "$ft/ttf" && tar -xf "$ft/$nerdfont_asset.zip" -C "$ft/ttf" 2>/dev/null
            fi
            if cp "$ft/ttf"/*.ttf "$font_dir"/ 2>/dev/null; then
                command -v fc-cache >/dev/null 2>&1 && fc-cache -f "$font_dir" >/dev/null 2>&1
                log "  installed $nerdfont_asset"
            else
                warn "  downloaded but could not place $nerdfont_asset .ttf files"
            fi
        else
            warn "  could not download $nerdfont_asset from the nerd-fonts release"
        fi
        rm -rf "$ft"
    fi
fi

# --- bat: rebuild theme cache ---
# The active theme ({{ .theme.names.bat }}) is built into bat, so no theme file
# is fetched; just rebuild the cache so a fresh install picks it up.
if command -v bat >/dev/null 2>&1; then
    bat cache --build >/dev/null 2>&1 || true
fi

# --- Report anything still missing ---
missing=""
for n in $names; do
    [ "$n" = "nerd-font" ] && continue
    b="$(bin_for "$n")"
    command -v "$b" >/dev/null 2>&1 || missing="$missing $b"
done
if [ -n "$missing" ]; then
    warn "Still missing:$missing"
    warn "Install these manually, or use Homebrew (covers all of them) and re-run: chezmoi apply"
else
    log "All tools present."
fi
