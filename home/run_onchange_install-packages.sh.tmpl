#!/usr/bin/env bash
# chezmoi run_onchange — installs/updates the CLI tool set on Unix.
# Re-runs automatically whenever the rendered package list below changes.
#
# packages.yaml sha256: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

# Pick up a Homebrew that run_once_before_install-homebrew may have just installed
# in this same `chezmoi apply` (its shellenv is not yet on our PATH).
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -x /usr/local/bin/brew ] && eval "$(/usr/local/bin/brew shellenv)"

# Package lists rendered from .chezmoidata/packages.yaml (empty fields omitted).
names="{{ range .packages }}{{ .name }} {{ end }}"
brew_pkgs="{{ range .packages }}{{ with .brew }}{{ . }} {{ end }}{{ end }}"
apt_pkgs="{{ range .packages }}{{ with .apt }}{{ . }} {{ end }}{{ end }}"
pacman_pkgs="{{ range .packages }}{{ with .pacman }}{{ . }} {{ end }}{{ end }}"
dnf_pkgs="{{ range .packages }}{{ with .dnf }}{{ . }} {{ end }}{{ end }}"

# --- Detect package manager ---
if command -v brew >/dev/null 2>&1; then
    MGR=brew
elif command -v apt-get >/dev/null 2>&1; then
    MGR=apt
elif command -v pacman >/dev/null 2>&1; then
    MGR=pacman
elif command -v dnf >/dev/null 2>&1; then
    MGR=dnf
else
    warn "No supported package manager found (brew/apt/pacman/dnf)."
    warn "Install Homebrew (https://brew.sh) for a one-command experience, then re-run: chezmoi apply"
    MGR=none
fi
log "Package manager: $MGR"

install_one() {
    pkg="$1"
    case "$MGR" in
        brew)   brew install "$pkg" >/dev/null 2>&1 || brew install --cask "$pkg" >/dev/null 2>&1 ;;
        apt)    sudo apt-get install -y "$pkg" >/dev/null 2>&1 ;;
        pacman) sudo pacman -S --needed --noconfirm "$pkg" >/dev/null 2>&1 ;;
        dnf)    sudo dnf install -y "$pkg" >/dev/null 2>&1 ;;
        *)      return 1 ;;
    esac
}

if [ "$MGR" != none ]; then
    case "$MGR" in
        brew)   pkgs="$brew_pkgs" ;;
        apt)    pkgs="$apt_pkgs"; sudo apt-get update -y >/dev/null 2>&1 || true ;;
        pacman) pkgs="$pacman_pkgs" ;;
        dnf)    pkgs="$dnf_pkgs" ;;
    esac
    for p in $pkgs; do
        log "install $p"
        install_one "$p" || warn "  could not install $p via $MGR (will try fallback)"
    done
fi

# --- Debian/Ubuntu rename: batcat -> bat, fdfind -> fd ---
mkdir -p "$HOME/.local/bin"
command -v batcat >/dev/null 2>&1 && [ ! -e "$HOME/.local/bin/bat" ] && ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
command -v fdfind >/dev/null 2>&1 && [ ! -e "$HOME/.local/bin/fd" ]  && ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"

# --- cargo fallback for tools the native manager could not provide ---
bin_for() {
    case "$1" in
        ripgrep) echo rg ;;
        neovim)  echo nvim ;;
        nushell) echo nu ;;
        *)       echo "$1" ;;
    esac
}
crate_for() {
    case "$1" in
        rg) echo ripgrep ;;
        fd) echo fd-find ;;
        bat) echo bat ;;
        eza) echo eza ;;
        zoxide) echo zoxide ;;
        starship) echo starship ;;
        delta) echo git-delta ;;
        nu) echo nu ;;
        *) echo "" ;;
    esac
}
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
if command -v cargo >/dev/null 2>&1; then
    for n in $names; do
        [ "$n" = "nerd-font" ] && continue
        b="$(bin_for "$n")"
        command -v "$b" >/dev/null 2>&1 && continue
        crate="$(crate_for "$b")"
        [ -z "$crate" ] && continue
        log "cargo install $crate (fallback for $b)"
        cargo install "$crate" >/dev/null 2>&1 || warn "  cargo install $crate failed"
    done
fi

# --- Nerd Font: guarantee the patched font is present (release fallback) ---
# Font identity comes from packages.yaml (nerdfont_asset); fetch the nerd-fonts
# release zip when the font is not already installed, so the terminal/prompt
# glyphs always resolve regardless of package-manager coverage. Idempotent.
nerdfont_asset="{{ range .packages }}{{ if hasKey . "nerdfont_asset" }}{{ .nerdfont_asset }}{{ end }}{{ end }}"
if [ -n "$nerdfont_asset" ]; then
    case "$(uname -s)" in
        Darwin) font_dir="$HOME/Library/Fonts" ;;
        *)      font_dir="$HOME/.local/share/fonts" ;;
    esac
    have_font=1
    ls "$font_dir/$nerdfont_asset"*.ttf >/dev/null 2>&1 || have_font=0
    if [ "$have_font" = 0 ] && command -v fc-list >/dev/null 2>&1; then
        fc-list 2>/dev/null | grep -qi "$nerdfont_asset" && have_font=1
    fi
    if [ "$have_font" = 0 ]; then
        log "install Nerd Font $nerdfont_asset (nerd-fonts release fallback)"
        mkdir -p "$font_dir"
        ft="$(mktemp -d)"
        if curl -fsSL -o "$ft/$nerdfont_asset.zip" \
            "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/$nerdfont_asset.zip"; then
            if command -v unzip >/dev/null 2>&1; then
                unzip -oq "$ft/$nerdfont_asset.zip" '*.ttf' -d "$ft/ttf" 2>/dev/null
            elif command -v python3 >/dev/null 2>&1; then
                python3 -m zipfile -e "$ft/$nerdfont_asset.zip" "$ft/ttf" >/dev/null 2>&1
            else
                mkdir -p "$ft/ttf" && tar -xf "$ft/$nerdfont_asset.zip" -C "$ft/ttf" 2>/dev/null
            fi
            if cp "$ft/ttf"/*.ttf "$font_dir"/ 2>/dev/null; then
                command -v fc-cache >/dev/null 2>&1 && fc-cache -f "$font_dir" >/dev/null 2>&1
                log "  installed $nerdfont_asset"
            else
                warn "  downloaded but could not place $nerdfont_asset .ttf files"
            fi
        else
            warn "  could not download $nerdfont_asset from the nerd-fonts release"
        fi
        rm -rf "$ft"
    fi
fi

# --- bat: rebuild theme cache ---
# The active theme ({{ .theme.names.bat }}) is built into bat, so no theme file
# is fetched; just rebuild the cache so a fresh install picks it up.
if command -v bat >/dev/null 2>&1; then
    bat cache --build >/dev/null 2>&1 || true
fi

# --- Report anything still missing ---
missing=""
for n in $names; do
    [ "$n" = "nerd-font" ] && continue
    b="$(bin_for "$n")"
    command -v "$b" >/dev/null 2>&1 || missing="$missing $b"
done
if [ -n "$missing" ]; then
    warn "Still missing:$missing"
    warn "Install these manually, or use Homebrew (covers all of them) and re-run: chezmoi apply"
else
    log "All tools present."
fi
