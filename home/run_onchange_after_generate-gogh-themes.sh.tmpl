#!/usr/bin/env bash
# chezmoi run_onchange — generates the live theme switcher's scheme catalog.
#
# Converts the Gogh terminal-theme collection (4-bit palettes: 16 ANSI colors +
# background/foreground) into base24 scheme files that tinty consumes, written to
# tinty's custom-schemes dir. This is what makes "works with every tool" true:
# each Gogh theme becomes a complete base24 palette tinty renders through its
# per-app templates. Re-runs only when this script's content changes (the pinned
# Gogh ref below is part of that content, so bumping the ref regenerates).
#
# Output is runtime state under tinty's data dir — outside the chezmoi-managed
# tree, so `chezmoi apply` never clobbers it. Idempotent: a ref marker short-
# circuits the download+convert on every subsequent run.
#
# Gogh ref: {{ "0aee76d9ade318fd9a4fb5a1dbd1cfc866e86307" }}
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

GOGH_REF="0aee76d9ade318fd9a4fb5a1dbd1cfc866e86307"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tinted-theming/tinty"
SCHEMES_DIR="$DATA_DIR/custom-schemes/base24"
MARKER="$SCHEMES_DIR/.gogh-ref"

# Idempotent skip: already generated for this exact Gogh ref.
if [ -f "$MARKER" ] && [ "$(cat "$MARKER" 2>/dev/null)" = "$GOGH_REF" ]; then
    log "Gogh theme catalog already current ($GOGH_REF); nothing to do."
    exit 0
fi

if ! command -v python3 >/dev/null 2>&1; then
    warn "python3 not found — cannot convert Gogh themes; the \`theme\` switcher"
    warn "will have no schemes until python3 is available and you re-run chezmoi apply."
    exit 0
fi

mkdir -p "$SCHEMES_DIR"
td="$(mktemp -d)"
trap 'rm -rf "$td"' EXIT

log "fetch Gogh catalog @ $GOGH_REF"
if ! curl -fsSL -o "$td/gogh.tar.gz" "https://github.com/Gogh-Co/Gogh/archive/$GOGH_REF.tar.gz"; then
    warn "could not download the Gogh catalog; leaving existing schemes untouched."
    exit 0
fi
if ! tar -xzf "$td/gogh.tar.gz" -C "$td" 2>/dev/null; then
    warn "could not extract the Gogh catalog; leaving existing schemes untouched."
    exit 0
fi

json_dir="$td/Gogh-$GOGH_REF/data/json"
if [ ! -d "$json_dir" ]; then
    warn "Gogh catalog layout changed (no data/json at the pinned ref); skipping."
    exit 0
fi

log "convert Gogh themes -> base24 schemes in $SCHEMES_DIR"
python3 - "$json_dir" "$SCHEMES_DIR" <<'PY'
import json, os, sys, glob

json_dir, out_dir = sys.argv[1], sys.argv[2]

def mix(a, b, t):
    """Linear blend of two #rrggbb colors; t is the weight of b in [0,1]."""
    a, b = a.lstrip('#'), b.lstrip('#')
    out = []
    for i in (0, 2, 4):
        ca, cb = int(a[i:i+2], 16), int(b[i:i+2], 16)
        out.append(max(0, min(255, round(ca + (cb - ca) * t))))
    return '#%02x%02x%02x' % tuple(out)

WHITE, BLACK = '#ffffff', '#000000'

def to_base24(g):
    bg, fg = g['background'].lower(), g['foreground'].lower()
    c = {n: g['color_%02d' % n].lower() for n in range(1, 17)}
    # Mono ramp base01-04/06-07/10-11 is interpolated: Gogh gives only one bg
    # and one fg, so selection/comment/dim shades are synthesized. Accents map
    # straight from the 16 ANSI colors. base0F (brown) has no ANSI equivalent and
    # is editor-only (out of the terminal+shell live scope), so it proxies white.
    return {
        'base00': bg,
        'base01': mix(bg, fg, 0.10),
        'base02': mix(bg, fg, 0.20),
        'base03': mix(bg, fg, 0.35),
        'base04': mix(bg, fg, 0.65),
        'base05': fg,
        'base06': mix(fg, WHITE, 0.30),
        'base07': mix(fg, WHITE, 0.60),
        'base08': c[2],   # red
        'base09': c[10],  # bright red ~ orange
        'base0A': c[4],   # yellow
        'base0B': c[3],   # green
        'base0C': c[7],   # cyan
        'base0D': c[5],   # blue
        'base0E': c[6],   # magenta / purple
        'base0F': c[8],   # white (brown proxy; editor-only slot)
        'base10': mix(bg, BLACK, 0.30),  # darker bg
        'base11': mix(bg, BLACK, 0.60),  # darkest bg
        'base12': c[10],  # bright red
        'base13': c[12],  # bright yellow
        'base14': c[11],  # bright green
        'base15': c[15],  # bright cyan
        'base16': c[13],  # bright blue
        'base17': c[14],  # bright magenta
    }

def yaml_escape(s):
    return str(s).replace('\\', '\\\\').replace('"', '\\"')

ORDER = ['base%02X' % i for i in range(24)]  # base00..base17 (hex-cased keys)
count = 0
for path in sorted(glob.glob(os.path.join(json_dir, '*.json'))):
    slug = os.path.splitext(os.path.basename(path))[0]
    try:
        g = json.load(open(path))
        pal = to_base24(g)
    except Exception as e:
        sys.stderr.write('  skip %s: %s\n' % (slug, e))
        continue
    variant = g.get('variant', 'dark') or 'dark'
    name = g.get('name', slug)
    lines = [
        'system: "base24"',
        'name: "%s"' % yaml_escape(name),
        'author: "Gogh (https://github.com/Gogh-Co/Gogh), converted for tinty"',
        'variant: "%s"' % yaml_escape(variant),
        'palette:',
    ]
    lines += ['  %s: "%s"' % (k, pal[k]) for k in ORDER]
    with open(os.path.join(out_dir, slug + '.yaml'), 'w') as fh:
        fh.write('\n'.join(lines) + '\n')
    count += 1

print('  wrote %d base24 schemes' % count)
PY

echo "$GOGH_REF" > "$MARKER"
log "Gogh theme catalog ready."
