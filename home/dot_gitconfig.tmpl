[user]
    name = {{ .name }}
    email = {{ .email }}

[init]
    defaultBranch = main

# Route github.com auth through gh (gh auth git-credential) so pushes follow
# gh's active account instead of Git Credential Manager's cached token. The
# empty `helper =` resets the inherited helper list for these URLs only, so the
# system-level `manager` helper does NOT also fire for github.com; every other
# host (e.g. Azure DevOps) still uses `manager`. Requires gh on PATH (installed
# via packages.yaml). This is what `gh auth setup-git` writes, made declarative.
[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential

[core]
    pager = delta
    autocrlf = {{ if eq .chezmoi.os "windows" }}true{{ else }}input{{ end }}

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    side-by-side = false
    syntax-theme = {{ .theme.names.delta }}
    # Diff frame accents from the central theme (home/.chezmoidata/theme.yaml).
    minus-style                   = syntax "{{ .theme.diff.minus_bg }}"
    minus-non-emph-style          = syntax "{{ .theme.diff.minus_bg }}"
    minus-emph-style              = syntax "{{ .theme.diff.minus_emph_bg }}"
    plus-style                    = syntax "{{ .theme.diff.plus_bg }}"
    plus-non-emph-style           = syntax "{{ .theme.diff.plus_bg }}"
    plus-emph-style               = syntax "{{ .theme.diff.plus_emph_bg }}"
    line-numbers-minus-style      = "{{ .theme.palette.red }}"
    line-numbers-plus-style       = "{{ .theme.palette.green }}"
    line-numbers-zero-style       = "{{ .theme.palette.gray }}"
    file-style                    = bold "{{ .theme.palette.fg1 }}"
    hunk-header-style             = "{{ .theme.palette.blue }}" bold

[merge]
    conflictStyle = zdiff3

[diff]
    colorMoved = default
    algorithm = histogram

[pull]
    rebase = true

[push]
    autoSetupRemote = true
    default = current

[fetch]
    prune = true

[rebase]
    autoStash = true
    autoSquash = true

[column]
    ui = auto

[branch]
    sort = -committerdate

[alias]
    s = status -sb
    co = checkout
    sw = switch
    br = branch
    cm = commit -m
    ca = commit --amend
    can = commit --amend --no-edit
    unstage = restore --staged
    last = log -1 HEAD --stat
    lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) %C(dim white)%an%C(reset) %C(green)(%ar)%C(reset)%C(auto)%d%C(reset)%n          %s'
    undo = reset --soft HEAD~1
    wip = !git add -A && git commit -m 'wip'
    aliases = config --get-regexp ^alias\\.
