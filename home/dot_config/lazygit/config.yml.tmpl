# lazygit configuration — theme managed centrally in
# home/.chezmoidata/theme.yaml (Gruvbox Dark Hard, orange accent).
gui:
  nerdFontsVersion: "3"
  scrollHeight: 2
  showFileTree: true
  showRandomTip: false
  showCommandLog: false
  theme:
    activeBorderColor:
      - "{{ .theme.palette.orange }}"
      - bold
    inactiveBorderColor:
      - "{{ .theme.palette.fg4 }}"
    optionsTextColor:
      - "{{ .theme.palette.blue }}"
    selectedLineBgColor:
      - "{{ .theme.palette.bg2 }}"
    cherryPickedCommitBgColor:
      - "{{ .theme.palette.bg3 }}"
    cherryPickedCommitFgColor:
      - "{{ .theme.palette.orange }}"
    unstagedChangesColor:
      - "{{ .theme.palette.red }}"
    defaultFgColor:
      - "{{ .theme.palette.fg1 }}"
    searchingActiveBorderColor:
      - "{{ .theme.palette.yellow }}"

git:
  paging:
    colorArg: always
    pager: delta --dark --paging=never
  parseEmoji: true

os:
  editPreset: "nvim"
