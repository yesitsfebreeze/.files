// Zellij — the terminal multiplexer (tabs, panes, session restore).
// WezTerm (or any host terminal) is just the window; all multiplexing lives here.
// Read from $XDG_CONFIG_HOME/zellij/config.kdl (XDG_CONFIG_HOME is set by env.nu).

// Run Nushell inside every pane, on every OS (incl. WSL on Windows).
default_shell "nu"

// Default layout (see layouts/default.kdl): one tab, with tab-bar + status-bar.
default_layout "default"

// Catppuccin Mocha to match WezTerm/Starship. Built into recent Zellij; if an
// older Zellij lacks it, it falls back to the default theme harmlessly.
theme "catppuccin-mocha"

// Session resurrection: serialize running sessions to disk so `zellij attach`
// (and our shell auto-start) resumes layout + pane viewports after a full
// restart. This is the built-in replacement for the removed resurrect.wezterm.
session_serialization true
serialize_pane_viewport true

// Quality-of-life.
copy_on_select true
pane_frames true
show_startup_tips false
mouse_mode true
