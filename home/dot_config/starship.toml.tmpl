# Starship prompt — identical on Nushell across Linux / WSL / macOS.
# Theme: managed centrally in home/.chezmoidata/theme.yaml (Gruvbox Dark Hard).
# The palette below is templated; the key names are layout-slot names used by
# the format strings, each mapped to a theme color.

"$schema" = "https://starship.rs/config-schema.json"

# Don't insert a blank line above the prompt on each new command.
add_newline = false

format = """
[](surface0)\
$os\
$username\
[](bg:peach fg:surface0)\
$directory\
[](fg:peach bg:green)\
$git_branch\
$git_status\
[](fg:green bg:teal)\
$nodejs\
$rust\
$golang\
$python\
[](fg:teal bg:blue)\
$cmd_duration\
[](fg:blue)\
$line_break\
$character"""

palette = "theme"

[palettes.theme]
surface0 = "{{ .theme.palette.bg1 }}"
peach    = "{{ .theme.palette.orange }}"
green    = "{{ .theme.palette.green }}"
teal     = "{{ .theme.palette.aqua }}"
blue     = "{{ .theme.palette.blue }}"
crust    = "{{ .theme.palette.bg0 }}"
text     = "{{ .theme.palette.fg1 }}"
red      = "{{ .theme.palette.red }}"

[os]
disabled = false
style = "bg:surface0 fg:text"

[os.symbols]
Macos = "󰀵"
Linux = "󰌽"
Arch = "󰣇"
Ubuntu = "󰕈"
Debian = "󰣚"

[username]
show_always = true
style_user = "bg:surface0 fg:text"
style_root = "bg:surface0 fg:red"
format = '[ $user ]($style)'

[directory]
style = "fg:crust bg:peach"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "…/"

[directory.substitutions]
"Documents" = "󰈙"
"Downloads" = " "
"Music" = "󰝚"
"Pictures" = " "
"Developer" = "󰲋"

[git_branch]
symbol = ""
style = "bg:green"
format = '[ $symbol $branch ](fg:crust bg:green)'

[git_status]
style = "bg:green"
format = '[$all_status$ahead_behind ](fg:crust bg:green)'

[cmd_duration]
min_time = 500
style = "fg:crust bg:blue"
format = '[  $duration ]($style)'

[nodejs]
symbol = ""
style = "bg:teal"
format = '[ $symbol ($version) ](fg:crust bg:teal)'

[rust]
symbol = ""
style = "bg:teal"
format = '[ $symbol ($version) ](fg:crust bg:teal)'

[golang]
symbol = ""
style = "bg:teal"
format = '[ $symbol ($version) ](fg:crust bg:teal)'

[python]
symbol = ""
style = "bg:teal"
format = '[ $symbol ($version) ](fg:crust bg:teal)'

[character]
success_symbol = "[](bold green)"
error_symbol = "[](bold red)"
vimcmd_symbol = "[](bold blue)"
