{
  "title": "Wallpaper — wrap any source",
  "type": "web",
  "file": "index.html",
  "preview": "preview.jpg",
  "description": "Wrap any video / web / image background with typing-reactive blur, brightness, opacity, zoom and vignette. The wpstats helper is only needed for the keyboard-activity (typing) reaction and for local-file / mp4 backgrounds. Need a background? Grab live ones from https://motionbgs.com",
  "tags": ["Web", "Abstract"],
  "general": {
    "properties": {
      "helperurl": {
        "order": 0,
        "text": "Helper URL (keyboard activity + local files)",
        "type": "textinput",
        "value": "http://localhost:8787/stats"
      },

      "bg_image": {
        "order": 10,
        "text": "Use image background",
        "type": "bool",
        "value": false
      },
      "bgimage": {
        "order": 11,
        "text": "    ↳ image file",
        "type": "file",
        "fileType": "image",
        "value": "",
        "condition": "bg_image.value == true"
      },
      "bg_video": {
        "order": 12,
        "text": "Use video background",
        "type": "bool",
        "value": false
      },
      "bgvideo": {
        "order": 13,
        "text": "    ↳ video file (webm/ogg picker)",
        "type": "file",
        "fileType": "video",
        "value": "",
        "condition": "bg_video.value == true"
      },
      "bgvideopath": {
        "order": 14,
        "text": "    ↳ or paste mp4/video path or URL (auto-converts mp4)",
        "type": "textinput",
        "value": "",
        "condition": "bg_video.value == true"
      },
      "bg_web": {
        "order": 15,
        "text": "Use web page background",
        "type": "bool",
        "value": false
      },
      "bgweburl": {
        "order": 16,
        "text": "    ↳ URL: YouTube / Vimeo / video / image / any page",
        "type": "textinput",
        "value": "",
        "condition": "bg_web.value == true"
      },

      "blur": {
        "order": 30,
        "text": "Blur",
        "type": "slider",
        "value": 0,
        "min": 0,
        "max": 40,
        "step": 1
      },
      "blur_typing": {
        "order": 31,
        "text": "    ↳ when typing",
        "type": "slider",
        "value": 0,
        "min": 0,
        "max": 40,
        "step": 1
      },
      "brightness": {
        "order": 32,
        "text": "Brightness",
        "type": "slider",
        "value": 100,
        "min": 0,
        "max": 200,
        "step": 1
      },
      "brightness_typing": {
        "order": 33,
        "text": "    ↳ when typing",
        "type": "slider",
        "value": 100,
        "min": 0,
        "max": 200,
        "step": 1
      },
      "bgopacity": {
        "order": 34,
        "text": "Opacity",
        "type": "slider",
        "value": 100,
        "min": 0,
        "max": 100,
        "step": 1
      },
      "bgopacity_typing": {
        "order": 35,
        "text": "    ↳ when typing",
        "type": "slider",
        "value": 100,
        "min": 0,
        "max": 100,
        "step": 1
      },
      "zoom": {
        "order": 36,
        "text": "Zoom",
        "type": "slider",
        "value": 100,
        "min": 100,
        "max": 250,
        "step": 1
      },
      "zoom_typing": {
        "order": 37,
        "text": "    ↳ when typing",
        "type": "slider",
        "value": 100,
        "min": 100,
        "max": 250,
        "step": 1
      },
      "vignette": {
        "order": 38,
        "text": "Vignette",
        "type": "slider",
        "value": 0,
        "min": 0,
        "max": 100,
        "step": 1
      },
      "vignette_typing": {
        "order": 39,
        "text": "    ↳ when typing",
        "type": "slider",
        "value": 0,
        "min": 0,
        "max": 100,
        "step": 1
      },

      "typingstartdelay":  { "order": 90, "text": "Typing transition · start delay sec (before fade in)",  "type": "slider", "value": 0.01, "min": 0.01, "max": 60, "step": 0.01 },
      "typingease":        { "order": 91, "text": "Typing transition · speed sec",                         "type": "slider", "value": 0.6,  "min": 0.01, "max": 60, "step": 0.01 },
      "typingrevertdelay": { "order": 92, "text": "Typing transition · revert delay sec (before fade out)", "type": "slider", "value": 0.6,  "min": 0.01, "max": 60, "step": 0.01 }
    }
  }
}
