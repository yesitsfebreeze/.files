# Television (tv) config, rendered by chezmoi from the central theme. Only
# theme-coupled values live here; re-theme the machine via .chezmoidata/theme.yaml,
# not this file. `{{ .theme.names.television }}` is a builtin tv theme (no fetch).

[ui]
theme = "{{ .theme.names.television }}"

[ui.input_bar]
border_type = "rounded"

[ui.results_panel]
border_type = "rounded"

[ui.preview_panel]
border_type = "rounded"
