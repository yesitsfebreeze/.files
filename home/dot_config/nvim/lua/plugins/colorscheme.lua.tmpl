-- Colorscheme — the editor half of the unified theme.
-- Theme + cursor are managed centrally in home/.chezmoidata/theme.yaml.
-- NOTE: the setup() call below is specific to {{ .theme.names.nvim_plugin }};
-- swapping to a different theme family means adjusting this spec, not just data.
return {
    "{{ .theme.names.nvim_plugin }}",
    priority = 1000,
    lazy = false,
    opts = {
        contrast = "{{ .theme.names.nvim_contrast }}",
        transparent_mode = false,
        terminal_colors = true,
    },
    config = function(_, opts)
        require("gruvbox").setup(opts)
        vim.o.background = "{{ .theme.names.nvim_background }}"
        vim.cmd.colorscheme("{{ .theme.names.nvim_colorscheme }}")
        -- Blinking block cursor in all modes (see theme.cursor.nvim_guicursor).
        vim.opt.guicursor = "{{ .theme.cursor.nvim_guicursor }}"
    end,
}
