#!/usr/bin/env bash
# chezmoi run_onchange — registers Claude Code marketplaces and installs the
# plugin set via the `claude` CLI at user scope. These are JS/MCP plugins run by
# the Node hosting Claude Code, not PATH binaries, so they live outside the
# package-manager installer (run_onchange_install-packages).
#
# Re-runs whenever the rendered plugin list below changes. `marketplace add` and
# `install` are idempotent, so re-running is safe; failures warn but never abort
# the apply (a machine without the claude CLI simply skips this step).
#
# packages.yaml sha256: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

if ! command -v claude >/dev/null 2>&1; then
    warn "claude CLI not found; skipping Claude Code plugin install"
    exit 0
fi
{{ range .claude_plugins }}
log "claude plugin: {{ .name }} ({{ .marketplace }})"
claude plugin marketplace add "{{ .marketplace }}" \
    || warn "  marketplace {{ .marketplace }} already present or could not be added"
claude plugin install "{{ .name }}@{{ .market }}" \
    || warn "  could not install {{ .name }}@{{ .market }} (may already be installed)"
{{ end }}