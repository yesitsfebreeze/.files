{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.3.1/resources/zpack-schema.json",
  "name": "custom-topbar",
  "version": "1.0.0",
  "description": "Custom minimal top bar.",
  "tags": ["topbar"],
  "widgets": [
    {
      "name": "topbar",
      "htmlPath": "./index.html",
      "zOrder": "top_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "includeFiles": ["*.html", "*.css"],
      "caching": { "defaultDuration": 0, "rules": [] },
      "privileges": { "shellCommands": [] },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "35px",
          "monitorSelection": { "type": "primary" },
          "dockToEdge": { "enabled": true, "edge": "top", "windowMargin": "0px" }
        }
      ]
    },
    {
      "name": "picker",
      "htmlPath": "./picker.html",
      "zOrder": "top_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "includeFiles": ["*.html", "*.css"],
      "caching": { "defaultDuration": 0, "rules": [] },
      "privileges": { "shellCommands": [] },
      "presets": [
        {
          "name": "default",
          "anchor": "center",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "100%",
          "monitorSelection": { "type": "primary" }
        }
      ]
    }
  ]
}
