# GlazeWM — Windows tiling WM config (i3-style). Lives at the default
# ~/.glzr/glazewm/config.yaml. Modifier is alt throughout.
# Every window lives in one equal grid: `initial_state: tiling` forces new windows into
# the tiling tree, so a window only ever leaves the grid when the user fullscreens it
# (alt+f) or detaches/floats it (alt+shift+space). Nothing is auto-floated. Equal pane
# sizes are kept by the balance-daemon (started below). Manual resize is intentionally
# absent (superseded by always-equal).

general:
  # Launch Zebar + the balance daemon with the WM. shell-exec runs through the
  # Windows shell, so %USERPROFILE% expands to the user profile. --hide-window keeps
  # node's console hidden (it's a background daemon). Non-fatal if absent.
  startup_commands:
    - 'shell-exec zebar startup'
    - 'shell-exec --hide-window node %USERPROFILE%/.glzr/glazewm/balance-daemon.js'
  shutdown_commands: []
  config_reload_commands: []
  focus_follows_cursor: false
  toggle_workspace_on_refocus: false
  cursor_jump:
    enabled: true
    trigger: 'monitor_focus'
  hide_method: 'cloak'
  show_all_in_taskbar: false

gaps:
  # Flat logical px on every display: with scale_with_dpi the same 12px was
  # multiplied by each monitor's DPI factor, so macOS (Retina 2x) drew gaps
  # ~2x larger than Windows. Off → 12px means 12px everywhere, unified.
  scale_with_dpi: false
  inner_gap: '12px'
  outer_gap:
    top: '12px'
    right: '12px'
    bottom: '12px'
    left: '12px'

window_effects:
  # Borders are Windows 11-only.
  focused_window:
    border:
      enabled: true
      # Active-window outline tracks the tinty theme's green (base0B). The value
      # is rendered by chezmoi from .chezmoidata/theme.toml's `green` (the single
      # synced source of truth), so this file never carries a per-machine color and
      # never conflicts. On a live `theme` switch wezterm-colors.sh also rewrites the
      # deployed copy's `tinty:base0B` line for instant effect — edit neither by hand.
      color: '{{ .theme.green }}' # tinty:base0B
  other_windows:
    border:
      enabled: false
      color: '#a1a1a1'

window_behavior:
  initial_state: 'tiling'
  state_defaults:
    floating:
      centered: true
      # Floating windows are popups by nature here (nothing auto-floats; a window
      # only floats when detached with alt+shift+space) — keep them above the
      # tiled grid like a native popup instead of letting them sink behind it.
      shown_on_top: true
    fullscreen:
      maximized: false
      shown_on_top: false

# Window rules run when a window is first managed; matchers are process/class/title
# only (there is no state matcher OR size matcher in the schema). New windows tile by
# default (initial_state above) and join the equal grid like any other — transient
# dialogs (file pickers, save prompts) included. Nothing is auto-floated or
# auto-fullscreened; balance-daemon.js only keeps the existing panes equal.
window_rules:
  # Zebar is our top status bar, not an app window — ignore it so GlazeWM never
  # hands it a tiling slot. Without this the bar's overlay window is managed like
  # any other and steals tiling space. Matches the Zebar process (covers the bar
  # and any Zebar popups).
  - commands: ['ignore']
    match:
      - window_process: { equals: 'zebar' }

  # Browser picture-in-picture / pop-out video players (YouTube etc.). Ignoring
  # them leaves the browser's native behavior intact: the popup keeps its own
  # always-on-top flag, stays freely draggable/resizable and never takes a tiling
  # slot. Rule is from the upstream sample config, extended with the German
  # window titles ("Bild-im-Bild" / "Bild im Bild") used on localized systems.
  # Both title AND class must match, so normal browser windows are unaffected.
  # Chrome_WidgetWin_1 covers Chrome/Edge/Brave; MozillaDialogClass is Firefox.
  - commands: ['ignore']
    match:
      - window_title: { regex: '[Pp]icture.in.[Pp]icture|[Bb]ild.im.[Bb]ild' }
        window_class: { regex: 'Chrome_WidgetWin_1|MozillaDialogClass' }

  # PowerToys popups (upstream sample-config rules): the PowerAccent character
  # picker, the Command Palette, and Peek preview windows are transient overlays,
  # not app windows — tiling them breaks their flow. Only the PowerToys rules are
  # taken from upstream; its Office/Lively/CleanShot rules are omitted because
  # those apps aren't installed here.
  - commands: ['ignore']
    match:
      - window_process: { equals: 'PowerToys' }
        window_class: { regex: 'HwndWrapper\[PowerToys\.PowerAccent.*?\]' }
      - window_title: { equals: 'Command Palette' }
        window_class: { equals: 'WinUIDesktopWin32WindowClass' }
      - window_process: { equals: 'PowerToys' }
        window_title: { regex: '.*? - Peek' }

workspaces:
  - name: '1'
  - name: '2'
  - name: '3'
  - name: '4'
  - name: '5'
  - name: '6'
  - name: '7'
  - name: '8'
  - name: '9'

keybindings:
  # Focus windows (vim keys + arrows).
  - commands: ['focus --direction left']
    bindings: ['alt+h', 'alt+left']
  - commands: ['focus --direction right']
    bindings: ['alt+l', 'alt+right']
  - commands: ['focus --direction up']
    bindings: ['alt+k', 'alt+up']
  - commands: ['focus --direction down']
    bindings: ['alt+j', 'alt+down']

  # Move the focused window.
  - commands: ['move --direction left']
    bindings: ['alt+shift+h', 'alt+shift+left']
  - commands: ['move --direction right']
    bindings: ['alt+shift+l', 'alt+shift+right']
  - commands: ['move --direction up']
    bindings: ['alt+shift+k', 'alt+shift+up']
  - commands: ['move --direction down']
    bindings: ['alt+shift+j', 'alt+shift+down']

  # Tiling direction / layout.
  - commands: ['toggle-tiling-direction']
    bindings: ['alt+v']

  # Regrid: pull every floating/fullscreen window on the focused workspace back into the
  # equal grid. GlazeWM keybindings only act on the focused window, so the sweep lives in
  # regrid.js over IPC; the balance daemon equalizes sizes afterward.
  - commands: ['shell-exec --hide-window node %USERPROFILE%/.glzr/glazewm/regrid.js']
    bindings: ['alt+g']

  # App picker overlay: alt+tab enters the 'picker' binding mode (below); the
  # always-running Zebar picker widget observes the mode over IPC and shows a
  # fullscreen 3x3 workspace matrix listing every window. Pure binding-mode
  # signalling — the overlay never needs keyboard focus, which a background
  # process can't reliably steal on Windows.
  - commands: ['wm-enable-binding-mode --name picker']
    bindings: ['alt+tab']

  # Window state.
  - commands: ['toggle-floating --centered']
    bindings: ['alt+shift+space']
  - commands: ['toggle-fullscreen']
    bindings: ['alt+f']
  - commands: ['toggle-minimized']
    bindings: ['alt+m']
  - commands: ['close']
    bindings: ['alt+shift+q']

  # WM control.
  - commands: ['wm-reload-config']
    bindings: ['alt+shift+r']
  - commands: ['wm-redraw']
    bindings: ['alt+shift+w']
  - commands: ['wm-exit']
    bindings: ['alt+shift+e']

  # Focus / move to workspace.
  - commands: ['focus --workspace 1']
    bindings: ['alt+1']
  - commands: ['focus --workspace 2']
    bindings: ['alt+2']
  - commands: ['focus --workspace 3']
    bindings: ['alt+3']
  - commands: ['focus --workspace 4']
    bindings: ['alt+4']
  - commands: ['focus --workspace 5']
    bindings: ['alt+5']
  - commands: ['focus --workspace 6']
    bindings: ['alt+6']
  - commands: ['focus --workspace 7']
    bindings: ['alt+7']
  - commands: ['focus --workspace 8']
    bindings: ['alt+8']
  - commands: ['focus --workspace 9']
    bindings: ['alt+9']

  - commands: ['focus --next-active-workspace']
    bindings: ['alt+s']
  - commands: ['focus --prev-active-workspace']
    bindings: ['alt+a']

  - commands: ['move --workspace 1']
    bindings: ['alt+shift+1']
  - commands: ['move --workspace 2']
    bindings: ['alt+shift+2']
  - commands: ['move --workspace 3']
    bindings: ['alt+shift+3']
  - commands: ['move --workspace 4']
    bindings: ['alt+shift+4']
  - commands: ['move --workspace 5']
    bindings: ['alt+shift+5']
  - commands: ['move --workspace 6']
    bindings: ['alt+shift+6']
  - commands: ['move --workspace 7']
    bindings: ['alt+shift+7']
  - commands: ['move --workspace 8']
    bindings: ['alt+shift+8']
  - commands: ['move --workspace 9']
    bindings: ['alt+shift+9']

# Picker overlay input (alt+tab). While 'picker' is active, GlazeWM owns the
# keyboard and each navigation key pulses a transient 'picker-<action>' mode
# purely as an IPC signal to the Zebar picker widget. Binding modes REPLACE each
# other (no stacking), so a pulse is enable-signal + re-enable-picker; the widget
# keeps the overlay up while any picker* mode is active. GlazeWM requires modes
# to be declared, hence the signal-mode stubs below. Enter is confirmed by the
# widget itself: it focuses the selection and disables 'picker'. Escape (also
# bound in every stub as a rescue hatch in case a pulse ever sticks) always
# drops back to the normal keybindings.
binding_modes:
  - name: 'picker'
    keybindings:
{{- range $sig, $keys := dict
      "down"  (list "down" "j")
      "up"    (list "up" "k")
      "left"  (list "left" "h")
      "right" (list "right" "l")
      "next"  (list "tab" "alt+tab")
      "prev"  (list "shift+tab" "alt+shift+tab")
      "enter" (list "enter" "space") }}
      - commands: ['wm-enable-binding-mode --name picker-{{ $sig }}', 'wm-enable-binding-mode --name picker']
        bindings: [{{ range $i, $k := $keys }}{{ if $i }}, {{ end }}'{{ $k }}'{{ end }}]
{{- end }}
{{- range untilStep 1 10 1 }}
      - commands: ['wm-enable-binding-mode --name picker-{{ . }}', 'wm-enable-binding-mode --name picker']
        bindings: ['{{ . }}']
{{- end }}
      - commands: ['wm-disable-binding-mode --name picker']
        bindings: ['escape']
{{- range concat (list "down" "up" "left" "right" "next" "prev" "enter") (list "1" "2" "3" "4" "5" "6" "7" "8" "9") }}
  - name: 'picker-{{ . }}'
    keybindings:
      - commands: ['wm-disable-binding-mode --name picker-{{ . }}']
        bindings: ['escape']
{{- end }}
