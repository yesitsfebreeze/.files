{{- /*
    Linux/WSL is the target; macOS is supported via Homebrew. chezmoi never runs
    on the Windows host itself (WezTerm boots into WSL, where the Linux path runs).
    Gate the macOS-only Homebrew bootstrap out on every non-macOS system.
*/ -}}
{{ if ne .chezmoi.os "darwin" }}
install-homebrew.sh
{{ end }}

# WezTerm colors.lua and Zebar theme.css are generated artifacts, NOT tracked in
# git: run_after_generate-shell-init.sh.tmpl regenerates them at apply time by
# running `tinty apply <scheme>`, where <scheme> is the single synced source of
# truth in .chezmoidata/theme.toml. Tracking the generated files made every machine
# commit its own palette and collide; ignoring them here keeps chezmoi from managing
# the deployed copies the hooks own. (GlazeWM's one generated line is handled
# differently — config.yaml.tmpl renders it from theme.toml's `green`.)
.config/wezterm/colors.lua
.glzr/zebar/custom-topbar/theme.css
