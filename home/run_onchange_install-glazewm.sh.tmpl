#!/usr/bin/env bash
# chezmoi run_onchange — installs GlazeWM, the tiling window manager, on the two
# platforms it supports. Separate from install-packages.sh (CLI tools) because
# GlazeWM is a GUI app on per-OS channels, and the Windows install is driven from
# WSL through interop (winget.exe), not a native package manager.
#
#   macOS → brew cask from the glzr-io tap
#   WSL   → winget.exe install on the Windows host (where GlazeWM actually runs)
#   Linux → skipped (GlazeWM does not run on Linux)
#
# Config is deployed separately to ~/.glzr/glazewm/config.yaml (and mirrored to the
# Windows profile by run_after_mirror-config-to-windows.sh).
# bump to force a re-run: v1
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

{{ if eq .chezmoi.os "darwin" -}}
# macOS — Homebrew cask from the glzr-io tap. Idempotent: skip if app present.
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -x /usr/local/bin/brew ] && eval "$(/usr/local/bin/brew shellenv)"

if [ -d "/Applications/GlazeWM.app" ] || brew list --cask glazewm >/dev/null 2>&1; then
    log "GlazeWM already installed."
elif command -v brew >/dev/null 2>&1; then
    log "install GlazeWM (brew cask glzr-io/tap/glazewm)"
    brew install --cask glzr-io/tap/glazewm >/dev/null 2>&1 \
        && log "  installed GlazeWM — grant it Accessibility permission on first launch" \
        || warn "  could not install GlazeWM via brew"
else
    warn "GlazeWM: Homebrew not found; install brew (https://brew.sh) and re-run: chezmoi apply"
fi
{{- else -}}
# WSL → drive the Windows host's winget. Plain Linux has no GlazeWM, so bail unless
# we are inside WSL with winget.exe reachable over interop.
grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null || { log "GlazeWM: not macOS/WSL, skipping."; exit 0; }

winget="$(command -v winget.exe 2>/dev/null || true)"
[ -z "$winget" ] && { warn "GlazeWM: winget.exe not on PATH from WSL; install manually: winget install glzr-io.glazewm"; exit 0; }

if "$winget" list --id glzr-io.glazewm -e >/dev/null 2>&1; then
    log "GlazeWM already installed on Windows."
else
    log "install GlazeWM on Windows (winget glzr-io.glazewm)"
    "$winget" install --id glzr-io.glazewm -e --silent \
        --accept-source-agreements --accept-package-agreements >/dev/null 2>&1 \
        && log "  installed GlazeWM on Windows" \
        || warn "  winget install failed; run manually in Windows: winget install glzr-io.glazewm"
fi
{{- end }}
