#!/usr/bin/env bash
# chezmoi run_onchange — installs the glzr.io desktop stack. GlazeWM (the tiling
# window manager) is Windows-only; Zebar (the status bar) is cross-platform.
#
#   WSL     → winget.exe installs GlazeWM + Zebar + Node on the Windows host
#   macOS   → brew installs Zebar only (GlazeWM has no macOS build)
#   Linux   → skipped (neither app runs on plain Linux)
#
# Config is deployed separately to ~/.glzr/glazewm/config.yaml (and mirrored to the
# Windows profile by run_after_mirror-config-to-windows.sh). The layout-daemon
# (ships with the config) runs on the Windows host via Node, so Node is installed
# here too. Autostart at login is registered by run_onchange_after_register-
# glazewm-autostart.sh.tmpl.
# bump to force a re-run: v4
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

{{ if eq .chezmoi.os "darwin" -}}
# macOS → no GlazeWM build exists; install Zebar alone via Homebrew cask.
log "GlazeWM: no macOS build (Windows-only); installing Zebar only."
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
[ -x /usr/local/bin/brew ] && eval "$(/usr/local/bin/brew shellenv)"
if ! command -v brew >/dev/null 2>&1; then
    warn "Zebar: brew not found; install manually: brew install --cask zebar"
    exit 0
fi
if brew list --cask zebar >/dev/null 2>&1; then
    log "Zebar already installed (brew cask)."
else
    log "install Zebar (brew cask)"
    brew install --cask zebar >/dev/null 2>&1 \
        && log "  installed Zebar." \
        || warn "  brew install failed; run manually: brew install --cask zebar"
fi
exit 0
{{- else -}}
# WSL → drive the Windows host's winget. Plain Linux has no GlazeWM, so bail unless
# we are inside WSL with winget.exe reachable over interop.
grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null || { log "GlazeWM: not WSL, skipping."; exit 0; }

winget="$(command -v winget.exe 2>/dev/null || true)"
[ -z "$winget" ] && { warn "GlazeWM: winget.exe not on PATH from WSL; install manually: winget install glzr-io.glazewm"; exit 0; }

# GlazeWM (WM) + Zebar (status bar) + Node (layout daemon) on the Windows host,
# each guarded. Node is detected separately since it ships its own node.exe.
for pkg in glzr-io.glazewm glzr-io.zebar OpenJS.NodeJS; do
    if [ "$pkg" = "OpenJS.NodeJS" ] && command -v node.exe >/dev/null 2>&1; then
        log "Node already present on Windows (node.exe)."
        continue
    fi
    if "$winget" list --id "$pkg" -e >/dev/null 2>&1; then
        log "$pkg already installed on Windows."
    else
        log "install $pkg on Windows (winget)"
        "$winget" install --id "$pkg" -e --silent \
            --accept-source-agreements --accept-package-agreements >/dev/null 2>&1 \
            && log "  installed $pkg on Windows" \
            || warn "  winget install failed; run manually in Windows: winget install $pkg"
    fi
done
{{- end }}
