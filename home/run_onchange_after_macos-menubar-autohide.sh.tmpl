#!/usr/bin/env bash
# chezmoi run_onchange_after — macOS only. Auto-hide the system menu bar so the
# GlazeWM + Zebar top bar is the single top-of-screen bar, flush at y=0, matching
# the Windows layout (Windows has no menu bar). Without this, the always-on macOS
# menu bar sits above Zebar's bar and shifts GlazeWM's work area down, so the same
# shared config renders differently on the two platforms.
#
# `_HIHideMenuBar = true` is the "Automatically hide and show the menu bar:
# Always" setting (System Settings → Control Center). The menu bar still reveals
# on hover at the top edge; Zebar's bar content is edge-anchored, so the notch
# region (screen centre) stays clear.
#
# run_onchange: re-runs only when this script changes, and it's idempotent — it
# reads the current value and writes only on a mismatch, so a manual un-hide is
# left alone until the script itself changes. Best-effort and non-fatal.
# bump to force a re-run: v1
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

{{ if eq .chezmoi.os "darwin" -}}
want=1
have="$(defaults read NSGlobalDomain _HIHideMenuBar 2>/dev/null || echo unset)"

if [ "$have" = "$want" ]; then
    log "macOS menu bar: already set to auto-hide."
else
    log "macOS menu bar: enabling auto-hide (was: $have) so Zebar's bar matches Windows."
    if defaults write NSGlobalDomain _HIHideMenuBar -bool true 2>/dev/null; then
        # Nudge the UI to pick it up without a full logout. On recent macOS the
        # change may still need a re-login to take full effect — note that.
        killall SystemUIServer >/dev/null 2>&1 || true
        log "  set _HIHideMenuBar=true. If the menu bar is still pinned, log out/in once."
    else
        warn "  could not write _HIHideMenuBar; set it manually:"
        warn "    System Settings → Control Center → 'Automatically hide and show the menu bar' → Always"
    fi
fi
{{- else -}}
# Non-macOS (Linux/WSL): nothing to do — Windows/Linux have no macOS menu bar, and
# the bar is already flush at the top there.
log "menu-bar auto-hide: not macOS, skipping."
{{- end }}
