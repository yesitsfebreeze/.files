#!/usr/bin/env bash
# chezmoi run_onchange_after — registers the glzr.io stack to launch at login on
# every system where it actually runs, so a fresh boot comes up with the bar/WM
# already running. Idempotent: re-registering just overwrites the prior entry.
#
#   WSL     → a Startup-folder shortcut to GlazeWM on the Windows host. GlazeWM's
#             startup_commands then launch Zebar + the balance daemon, so one
#             shortcut brings up the whole stack.
#   macOS   → a LaunchAgent for Zebar (the only glzr app with a macOS build); there
#             is no GlazeWM to cascade from, so Zebar is registered directly.
#   Linux   → skipped (neither app runs on plain Linux).
#
# Best-effort and non-fatal: a missing toolchain is a warning, never an apply error.
# bump to force a re-run: v1
set -uo pipefail

log()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

{{ if eq .chezmoi.os "darwin" -}}
# macOS → a per-user LaunchAgent that opens Zebar at login. `open -a` lets launchd
# hand off to LaunchServices without us hardcoding the app bundle's inner path.
plist="$HOME/Library/LaunchAgents/io.glzr.zebar.plist"
mkdir -p "$HOME/Library/LaunchAgents"
cat > "$plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.glzr.zebar</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/open</string>
        <string>-a</string>
        <string>Zebar</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
PLIST
# Reload so the change takes effect this session, not just next login.
launchctl unload "$plist" >/dev/null 2>&1 || true
if launchctl load -w "$plist" >/dev/null 2>&1; then
    log "Zebar: registered LaunchAgent (autostart at login)."
else
    warn "Zebar: wrote $plist but launchctl load failed; it still loads next login."
fi
{{- else -}}
# WSL → drop a shortcut to GlazeWM in the Windows per-user Startup folder. Plain
# Linux has neither app, so bail unless we are inside WSL with interop.
grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null || { log "Autostart: not WSL, skipping."; exit 0; }

# Resolve the GUI launcher from the CLI on the interop PATH (cli/glazewm.exe lives
# one level under the app dir that holds the GUI glazewm.exe), falling back to the
# standard winget install location.
cli="$(command -v glazewm.exe 2>/dev/null || true)"
if [ -n "$cli" ]; then
    gui_unix="$(dirname "$(dirname "$cli")")/glazewm.exe"
else
    gui_unix="/mnt/c/Program Files/glzr.io/GlazeWM/glazewm.exe"
fi
[ -f "$gui_unix" ] || { warn "Autostart: GlazeWM.exe not found at $gui_unix; install it first."; exit 0; }

gui_win="$(wslpath -w "$gui_unix" 2>/dev/null || true)"
[ -z "$gui_win" ] && { warn "Autostart: could not map $gui_unix to a Windows path; skipping."; exit 0; }
gui_dir_win="${gui_win%\\*}"

command -v powershell.exe >/dev/null 2>&1 || { warn "Autostart: powershell.exe not on interop PATH; create the Startup shortcut manually."; exit 0; }

if powershell.exe -NoProfile -NonInteractive -Command "
\$ErrorActionPreference='Stop'
\$lnk = Join-Path ([Environment]::GetFolderPath('Startup')) 'GlazeWM.lnk'
\$s = (New-Object -ComObject WScript.Shell).CreateShortcut(\$lnk)
\$s.TargetPath = '$gui_win'
\$s.WorkingDirectory = '$gui_dir_win'
\$s.Save()
" >/dev/null 2>&1; then
    log "GlazeWM: registered Startup shortcut (autostart at login → cascades Zebar)."
else
    warn "GlazeWM: failed to write Startup shortcut; add one to shell:startup manually."
fi
{{- end }}
