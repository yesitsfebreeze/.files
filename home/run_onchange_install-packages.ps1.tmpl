# chezmoi run_onchange — installs/updates the CLI tool set on Windows.
# Re-runs automatically whenever the rendered package list below changes.
#
# packages.yaml sha256: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
$ErrorActionPreference = 'Continue'

function Log  { param($m) Write-Host ":: $m" -ForegroundColor Blue }
function Warn { param($m) Write-Host "!! $m" -ForegroundColor Yellow }

# Package ids rendered from .chezmoidata/packages.yaml (empty fields omitted).
$wingetIds = @(
{{- range .packages }}{{ with .winget }}
    "{{ . }}",
{{- end }}{{ end }}
    $null) | Where-Object { $_ }

$scoopPkgs = @(
{{- range .packages }}{{ with .scoop }}
    "{{ . }}",
{{- end }}{{ end }}
    $null) | Where-Object { $_ }

$haveWinget = [bool](Get-Command winget -ErrorAction SilentlyContinue)
$haveScoop  = [bool](Get-Command scoop  -ErrorAction SilentlyContinue)

if ($haveWinget) {
    Log "Installing via winget"
    foreach ($id in $wingetIds) {
        Log "install $id"
        winget install --id $id -e --silent --accept-package-agreements --accept-source-agreements 2>$null | Out-Null
    }
}
elseif ($haveScoop) {
    Log "Installing via scoop"
    scoop bucket add main 2>$null | Out-Null
    scoop bucket add extras 2>$null | Out-Null
    scoop bucket add nerd-fonts 2>$null | Out-Null
    foreach ($p in $scoopPkgs) {
        Log "install $p"
        scoop install $p 2>$null | Out-Null
    }
}
else {
    Warn "Neither winget nor scoop is available."
    Warn "Install winget (App Installer from the Microsoft Store) or scoop (https://scoop.sh), then re-run: chezmoi apply"
}

# --- bat: install Catppuccin Mocha theme + rebuild cache ---
if (Get-Command bat -ErrorAction SilentlyContinue) {
    $themeDir = Join-Path (bat --config-dir) "themes"
    New-Item -ItemType Directory -Force -Path $themeDir | Out-Null
    $themeFile = Join-Path $themeDir "Catppuccin Mocha.tmTheme"
    if (-not (Test-Path $themeFile)) {
        Log "fetch bat Catppuccin Mocha theme"
        try {
            Invoke-WebRequest -UseBasicParsing `
                -Uri "https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Mocha.tmTheme" `
                -OutFile $themeFile
        } catch { Warn "could not fetch bat theme" }
    }
    bat cache --build 2>$null | Out-Null
}

Log "Done. Restart the shell if PATH changed."
