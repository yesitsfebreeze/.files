# chezmoi run_onchange — installs/updates the CLI tool set on Windows.
# Re-runs automatically whenever the rendered package list below changes.
#
# packages.yaml sha256: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
$ErrorActionPreference = 'Continue'

function Log  { param($m) Write-Host ":: $m" -ForegroundColor Blue }
function Warn { param($m) Write-Host "!! $m" -ForegroundColor Yellow }

# Package ids rendered from .chezmoidata/packages.yaml (empty fields omitted).
$wingetIds = @(
{{- range .packages }}{{ with .winget }}
    "{{ . }}",
{{- end }}{{ end }}
    $null) | Where-Object { $_ }

$scoopPkgs = @(
{{- range .packages }}{{ with .scoop }}
    "{{ . }}",
{{- end }}{{ end }}
    $null) | Where-Object { $_ }

$haveWinget = [bool](Get-Command winget -ErrorAction SilentlyContinue)
$haveScoop  = [bool](Get-Command scoop  -ErrorAction SilentlyContinue)

if ($haveWinget) {
    Log "Installing via winget"
    foreach ($id in $wingetIds) {
        Log "install $id"
        winget install --id $id -e --silent --accept-package-agreements --accept-source-agreements 2>$null | Out-Null
    }
}
elseif ($haveScoop) {
    Log "Installing via scoop"
    scoop bucket add main 2>$null | Out-Null
    scoop bucket add extras 2>$null | Out-Null
    scoop bucket add nerd-fonts 2>$null | Out-Null
    foreach ($p in $scoopPkgs) {
        Log "install $p"
        scoop install $p 2>$null | Out-Null
    }
}
else {
    Warn "Neither winget nor scoop is available."
    Warn "Install winget (App Installer from the Microsoft Store) or scoop (https://scoop.sh), then re-run: chezmoi apply"
}

# --- Nerd Font: guarantee the patched font is present (release fallback) ---
# Font identity comes from packages.yaml (nerdfont_asset); fetch the nerd-fonts
# release zip when the font is not already installed, so glyphs always resolve
# regardless of winget/scoop coverage. Per-user install, no admin. Idempotent.
$nerdfontAsset = "{{ range .packages }}{{ if hasKey . "nerdfont_asset" }}{{ .nerdfont_asset }}{{ end }}{{ end }}"
if ($nerdfontAsset) {
    $fontDir = Join-Path $env:LOCALAPPDATA 'Microsoft\Windows\Fonts'
    $haveFont = (Test-Path (Join-Path $fontDir "$nerdfontAsset*.ttf"))
    if (-not $haveFont) {
        Log "install Nerd Font $nerdfontAsset (nerd-fonts release fallback)"
        New-Item -ItemType Directory -Force -Path $fontDir | Out-Null
        $regKey = 'HKCU:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Fonts'
        $tmp = Join-Path ([System.IO.Path]::GetTempPath()) "nf_$nerdfontAsset"
        $zip = "$tmp.zip"
        Remove-Item -Recurse -Force $tmp, $zip -ErrorAction SilentlyContinue
        try {
            Invoke-WebRequest -UseBasicParsing `
                -Uri "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/$nerdfontAsset.zip" `
                -OutFile $zip
            Expand-Archive -Path $zip -DestinationPath $tmp -Force
            foreach ($f in Get-ChildItem -Path $tmp -Recurse -Filter '*.ttf') {
                $dest = Join-Path $fontDir $f.Name
                Copy-Item -Path $f.FullName -Destination $dest -Force
                $regName = [System.IO.Path]::GetFileNameWithoutExtension($f.Name) + ' (TrueType)'
                New-ItemProperty -Path $regKey -Name $regName -Value $dest -PropertyType String -Force | Out-Null
            }
            Log "  installed $nerdfontAsset"
        } catch {
            Warn "  could not download/install $nerdfontAsset from the nerd-fonts release"
        }
        Remove-Item -Recurse -Force $tmp, $zip -ErrorAction SilentlyContinue
    }
}

# --- bat: rebuild theme cache ---
# The active theme ({{ .theme.names.bat }}) is built into bat, so no theme file
# is fetched; just rebuild the cache so a fresh install picks it up.
if (Get-Command bat -ErrorAction SilentlyContinue) {
    bat cache --build 2>$null | Out-Null
}

Log "Done. Restart the shell if PATH changed."
