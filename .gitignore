# kern runtime state — regenerated by the project layer, never committed
/.claude/
/.kern/
/.proj/
/.machine/

# Claude Code session-id file written into cwd by a SessionStart hook — runtime only
/.claude-session

# harness worker worktrees — transient, never committed into the dotfiles repo
/.worktrees/

# tinty live-theme runtime state — generated in the data dir, never the source
# tree. Belt-and-suspenders so a stray apply target can't commit it. Targets the
# generated artifact names only, so the tracked source config (home/dot_config/
# tinted-theming/tinty/config.toml) is deliberately NOT matched.
**/custom-schemes/
**/current_scheme

# OS cruft
.DS_Store
Thumbs.db
/.mesh/

# git-fs plugin runtime object store — never committed
/.git-fs/

home/dot_config/wezterm/colors.lua

# VOIT orchestration runtime + research vault — machine-local, never committed
/.voit/
/.voitbus.pid
/.voitbus.json
/vicky/

# Obsidian workspace state (vault UI + vendored plugins)
/.obsidian/
