# kern runtime state — regenerated by the project layer, never committed
/.claude/
/.kern/
/.proj/
/.machine/

# tinty live-theme runtime state — generated in the data dir, never the source
# tree. Belt-and-suspenders so a stray apply target can't commit it. Targets the
# generated artifact names only, so the tracked source config (home/dot_config/
# tinted-theming/tinty/config.toml) is deliberately NOT matched.
**/custom-schemes/
**/current_scheme

# OS cruft
.DS_Store
Thumbs.db
/.mesh/
